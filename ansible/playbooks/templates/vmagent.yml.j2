global:
  scrape_interval: 30s
  external_labels:
    server: "{{ inventory_hostname }}"
    ansible_host: "{{ ansible_host }}"

scrape_configs:
  - job_name: node
    static_configs:
      - targets:
          - node_exporter:9100

  - job_name: cadvisor
    static_configs:
      - targets:
          - cadvisor:8080

  - job_name: vmagent
    static_configs:
      - targets:
          - vmagent:8429
